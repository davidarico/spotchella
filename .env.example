# Copy to .env and fill in values.
# PostgreSQL — use a local instance or docker compose (see README)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/spotchella?schema=public"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""
# Comma-separated origins in production, e.g. https://spotchella.example.com
AUTH_TRUST_HOST="http://localhost:3000"
# App origin (no path). Use the same for both; `next.config` copies AUTH_URL → NEXTAUTH_URL for the client.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Spotify app: https://developer.spotify.com/dashboard
# Redirect URI (must match exactly — not /callback):
#   http://127.0.0.1:3000/api/auth/callback/spotify
#   or  http://localhost:3000/api/auth/callback/spotify
# (Same host in AUTH_URL, browser bar, and Spotify)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
